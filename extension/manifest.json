{
  "manifest_version": 3,
  "name": "MangaDex Discord Presence",
  "version": "1.0.0",
  "description": "Sends your MangaDex reading status to Discord Rich Presence",
  "permissions": ["tabs", "activeTab", "storage"],
  "host_permissions": [
    "https://api.mangadex.org/*",
    "http://localhost:43215/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mangadex.org/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
